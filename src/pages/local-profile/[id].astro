---
import Layout from "../../layouts/Layout.astro";
import type {
  RootObject,

  Service,
} from "../../interfaces/dbData";
import TransparentHeader from "../../components/global/TransparentHeader.astro";
import FormatText from "../../hooks/FormatText";

const { id } = Astro.params;

let API_URL = import.meta.env.API_URL;
const response = await fetch(`${API_URL}`);
const data: RootObject = await response.json();

const service = data.services.find(
  (item: Service) => FormatText(item.title) === id,
);

if (!service) {
  return Astro.redirect("/local-profile");
}

const primaryDescription = service.description[0];
const otherServices = data.services
  .filter((item: Service) => FormatText(item.title) !== id)
  .slice(0, 4);
const serviceAreas = data.dataGeneral.location
  .map((location) => location.city)
  .filter(Boolean);
const estimateText =
  data.estimateFree || "Contact us today for details about your estimate.";
const serviceSummary =
  primaryDescription?.text ||
  service.subtitle ||
  `Professional ${service.title} by ${data.name}.`;
const serviceHighlights = [
  {
    title: "Professional Results",
    description: `We deliver ${service.title.toLowerCase()} with attention to detail, reliable communication, and results built to last.`,
  },
  {
    title: "Custom Solutions",
    description: `Every project is adapted to the property, goals, and budget of each customer to ensure the right fit.`,
  },
  {
    title: "Straightforward Process",
    description:
      "From the first call to the final walkthrough, we keep the process clear, organized, and easy to follow.",
  },
];

const faqItems = [
  {
    question: "Do you offer free estimates?",
    answer: estimateText,
  },
  {
    question: "What areas do you serve?",
    answer:
      serviceAreas.length > 0
        ? `We serve ${serviceAreas.slice(0, 6).join(", ")}${serviceAreas.length > 6 ? ", and nearby areas." : "."}`
        : "Contact us to confirm service availability in your area.",
  },
];
---

<Layout
  title={`${service.title} | ${data.name}`}
  description={primaryDescription?.text!}
  favicon={data.logos.primary}
  featuredImage={primaryDescription?.image!}
  keywords={data.services.map((item) => item.title).join(", ")}
>
  <TransparentHeader title={service.title} image={primaryDescription?.image!} />
  <main class="bg-white text-slate-900">
    <section class="mx-auto w-[95%] max-w-6xl py-10 md:w-[90%] md:py-16">
      <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
        <div
          class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm"
        >
          <p
            class="text-sm font-semibold uppercase tracking-[0.28em] text-primary"
          >
            Featured service
          </p>
          <h1 class="mt-4 text-4xl font-bold leading-tight md:text-5xl">
            {service.title}
          </h1>
          <p
            class="mt-3 text-sm font-semibold uppercase tracking-[0.2em] text-slate-500"
          >
            for homeowners and businesses
          </p>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-700">
            {serviceSummary}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            {
              data.dataGeneral.phones.slice(0, 1).map((phone) => (
                <a
                  href={`tel:+1${phone.number}`}
                  class="inline-flex items-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition hover:opacity-90"
                >
                  Call {phone.number}
                </a>
              ))
            }
            <a
              href="/contact"
              class="inline-flex items-center rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:border-primary hover:text-primary"
            >
              Request a free quote
            </a>
          </div>

          <div class="mt-10 grid gap-5 md:grid-cols-3">
            <article class="rounded-2xl bg-slate-50 p-5">
              <p
                class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"
              >
                Estimates
              </p>
              <p class="mt-2 text-lg font-bold text-slate-900">
                {estimateText}
              </p>
            </article>
            <article class="rounded-2xl bg-slate-50 p-5">
              <p
                class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"
              >
                Experience
              </p>
              <p class="mt-2 text-lg font-bold text-slate-900">
                {data.yearsExperience || "Experienced team"}
              </p>
            </article>
            <article class="rounded-2xl bg-slate-50 p-5">
              <p
                class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"
              >
                Coverage
              </p>
              <p class="mt-2 text-lg font-bold text-slate-900">
                {
                  serviceAreas.length > 0
                    ? `${serviceAreas.length} areas served`
                    : "Wide local coverage"
                }
              </p>
            </article>
          </div>
        </div>

        <aside
          class="rounded-[2rem] border border-slate-200 bg-slate-50 p-6 shadow-sm"
        >
          <img
            src={data.logos.primary}
            alt={service.title}
            class="h-72 w-full rounded-[1.5rem] object-cover"
          />
          <div class="mt-6 rounded-[1.5rem] bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-bold text-slate-900">
              Why this service stands out
            </h2>
            <ul class="mt-5 space-y-4">
              {
                serviceHighlights.map((item) => (
                  <li class="rounded-2xl border border-slate-200 p-4">
                    <h3 class="text-lg font-bold text-slate-900">
                      {item.title}
                    </h3>
                    <p class="mt-2 leading-7 text-slate-700">
                      {item.description}
                    </p>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <section class="border-y border-slate-200 bg-slate-50">
      <div class="mx-auto w-[95%] max-w-6xl py-14 md:w-[90%] md:py-20">
        <div class="grid gap-6 lg:grid-cols-[1fr_0.9fr]">
          <article
            class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm"
          >
            <div class="flex items-end justify-between gap-4">
              <div>
                <p
                  class="text-sm font-semibold uppercase tracking-[0.28em] text-primary"
                >
                  More services
                </p>
                <h2 class="mt-3 text-3xl font-bold text-slate-900">
                  Explore related services
                </h2>
              </div>
              <a
                href="/services"
                class="hidden rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:border-primary hover:text-primary md:inline-flex"
              >
                View all
              </a>
            </div>
            <div class="mt-8 grid gap-4">
              {
                otherServices.map((item) => (
                  <a
                    href={`/local-profile/${FormatText(item.title)}`}
                    class="flex items-center justify-between rounded-[1.5rem] border border-slate-200 bg-slate-50 px-5 py-4 transition hover:border-primary/40 hover:bg-white"
                  >
                    <div>
                      <h3 class="text-lg font-bold text-slate-900">
                        {item.title}
                      </h3>
                      <p class="mt-1 text-sm text-slate-600">
                        {item.subtitle ||
                          item.description[0]?.text
                            ?.split(". ")
                            .slice(0, 1)
                            .join(". ") ||
                          "Learn more about this service."}
                      </p>
                    </div>
                    <span class="text-sm font-semibold text-primary">
                      Read more
                    </span>
                  </a>
                ))
              }
            </div>
            <div class="mt-6">
              <p
                class="text-sm font-semibold uppercase tracking-[0.28em] text-cyan-800"
              >
                Frequently asked questions
              </p>
              <div class="mt-2 space-y-4">
                {
                  faqItems.map((item) => (
                    <div class="rounded-2xl bg-white px-5">
                      <h3 class="text-lg font-bold text-slate-900">
                        {item.question}
                      </h3>
                      <p class="mt-2 leading-7 text-slate-700">{item.answer}</p>
                    </div>
                  ))
                }
              </div>
            </div>
          </article>

          <aside class="space-y-6">
            <div
              class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm"
            >
              <h2 class="text-2xl font-bold text-slate-900">Service areas</h2>
              <p class="mt-3 leading-7 text-slate-700">
                {
                  serviceAreas.length > 0
                    ? `We proudly serve ${serviceAreas.slice(0, 8).join(", ")}${serviceAreas.length > 8 ? ", and nearby areas." : "."}`
                    : "Contact us to confirm service availability in your location."
                }
              </p>
              <div class="mt-5 flex flex-wrap gap-3">
                {
                  serviceAreas
                    .slice(0, 10)
                    .map((area) => (
                      <span class="rounded-full border border-slate-300 bg-slate-50 px-4 py-2 text-sm text-slate-700">
                        {area}
                      </span>
                    ))
                }
              </div>
            </div>

            <div class="rounded-[2rem] bg-slate-900 p-6 text-white shadow-sm">
              <p
                class="text-sm font-semibold uppercase tracking-[0.28em] text-white"
              >
                Ready to start?
              </p>
              <h2 class="mt-3 text-3xl font-bold">{estimateText}</h2>
              <p class="mt-4 leading-7 text-slate-200">
                Reach out today to discuss your project, get answers to your
                questions, and schedule your next step.
              </p>
              <div class="mt-6 flex flex-col gap-3">
                {
                  data.dataGeneral.phones.slice(0, 2).map((phone) => (
                    <a
                      href={`tel:+1${phone.number}`}
                      class="inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-200"
                    >
                      {phone.title ? `${phone.title}: ` : "Call Us Now: "}{phone.number}
                    </a>
                  ))
                }
                <a
                  href="/contact"
                  class="inline-flex items-center justify-center rounded-full border border-white/20 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
                >
                  Go to contact form
                </a>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>


  </main>
</Layout>
