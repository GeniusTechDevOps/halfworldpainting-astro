---
import Layout from "../layouts/Layout.astro";
import type { RootObject } from "../interfaces/dbData";
import {
  buildAiPageStructuredData,
  getBusinessSummary,
  getPrimaryEmail,
  getPrimaryPhone,
  getServiceAreas,
  getSiteOrigin,
} from "../lib/aiDiscovery";
import TransparentHeader from "../components/global/TransparentHeader.astro";
import FormatText from "../hooks/FormatText";

let API_URL = import.meta.env.API_URL;
const response = await fetch(`${API_URL}`);
const data: RootObject = await response.json();
const siteOrigin = getSiteOrigin(data, Astro.request.url);
const serviceAreas = getServiceAreas(data);
const primaryPhone = getPrimaryPhone(data);
const primaryEmail = getPrimaryEmail(data);
const aiStructuredData = buildAiPageStructuredData(data, siteOrigin);
const serviceSummary = data.services.map((service) => service.title).join(", ");
const primaryGalleryImage = data.gallery[0] || data.logos.favicon;
const secondaryGalleryImage = data.gallery[2] || data.logos.favicon;
const whyChooseUsText =
  data.valuesContent.whychooseUs || getBusinessSummary(data);
const estimateText =
  data.estimateFree || "Contact us for current estimate information.";
const serviceAreaText =
  serviceAreas.length > 0
    ? `We proudly serve ${serviceAreas.slice(0, 6).join(", ")}${serviceAreas.length > 6 ? ", and nearby areas." : "."}`
    : "Contact us to confirm service availability in your area.";
const serviceCatalogIntro =
  data.slogan[3] || data.valuesContent.mission || getBusinessSummary(data);
const serviceCatalogDescription =
  data.valuesContent.mission ||
  data.valuesContent.whychooseUs ||
  getBusinessSummary(data);
---

<Layout
  title={`Local Profile | ${data.name}`}
  description={`Professional AI-readable overview for ${data.name}, including services, service areas, business details, and contact information.`}
  favicon={data.logos.primary}
  featuredImage={primaryGalleryImage}
  keywords={`${data.name}, ${serviceSummary}, AI overview, local business, service provider`}
  structuredData={aiStructuredData}
>
  <TransparentHeader title="Local Profile" image={secondaryGalleryImage} />

  <main class="text-primary">
    <section class="relative overflow-hidden bg-white">
      <div class="relative mx-auto max-w-7xl px-6 py-12 md:py-20">
        {/* Fondo decorativo sutil */}
        <div
          class="absolute -top-24 -left-24 h-96 w-96 rounded-full bg-cyan-100/50 blur-3xl"
        >
        </div>

        <div class="relative grid gap-8 lg:grid-cols-12">
          {/* COLUMNA IZQUIERDA: Contenido Principal (8 columnas) */}
          <div class="lg:col-span-8 flex flex-col justify-center">
            <div class="inline-flex items-center gap-2 mb-6">
              <span class="h-px w-8 bg-cyan-500"></span>
              <span
                class="text-xs font-bold uppercase tracking-widest text-secondary"
              >
                Local Profile
              </span>
            </div>

            <h1
              class="text-5xl font-extrabold tracking-tight text-primary md:text-7xl"
            >
              {data.name}
              <span
                class="block text-2xl md:text-3xl font-medium text-slate-400 mt-2"
              >
                Structured Business Overview
              </span>
            </h1>

            <p class="mt-8 max-w-2xl text-base leading-relaxed text-slate-600">
              {getBusinessSummary(data)}
            </p>

            {/* Botones de Acción Estilizados */}
            <div class="mt-10 flex flex-wrap gap-4">
              <a
                href="/contact"
                class="group relative inline-flex items-center overflow-hidden rounded-2xl bg-primary px-8 py-4 text-white transition-all hover:bg-slate-800 shadow-xl shadow-slate-200"
              >
                <span class="relative font-semibold">Request estimate</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>

              {
                primaryPhone && (
                  <a
                    href={`tel:+1${primaryPhone.replace(/[^0-9]/g, "")}`}
                    class="inline-flex items-center rounded-2xl border-2 border-slate-100 bg-white px-8 py-4 text-sm font-bold text-slate-700 transition-all hover:border-cyan-200 hover:bg-cyan-50/30"
                  >
                    Call {primaryPhone}
                  </a>
                )
              }
            </div>
          </div>

          {/* COLUMNA DERECHA: Card Visual & Stats (4 columnas) */}
          <aside class="lg:col-span-4">
            <div
              class="overflow-hidden rounded-[2.5rem] border border-slate-100 bg-white p-4 shadow-2xl shadow-slate-200/60"
            >
              <div class="relative h-64 w-full overflow-hidden rounded-[2rem]">
                <img
                  src={primaryGalleryImage}
                  alt={data.name}
                  class="h-full w-full object-cover transition-transform duration-700 hover:scale-110"
                />
                <div
                  class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"
                >
                </div>
              </div>

              {/* Mini Grid de Stats */}
              <div class="mt-4 grid grid-cols-2 gap-3">
                <div
                  class="rounded-[1.5rem] bg-slate-50 p-5 transition-colors hover:bg-cyan-50"
                >
                  <span
                    class="block text-xs font-bold uppercase tracking-tight text-slate-400"
                    >Services</span
                  >
                  <span class="mt-1 block text-3xl font-black text-primary"
                    >{data.services.length}</span
                  >
                </div>

                <div
                  class="rounded-[1.5rem] bg-slate-50 p-5 transition-colors hover:bg-cyan-50"
                >
                  <span
                    class="block text-xs font-bold uppercase tracking-tight text-slate-400"
                    >Exp.</span
                  >
                  <span class="mt-1 block text-3xl font-black text-primary"
                    >{data.yearsExperience || "—"}</span
                  >
                </div>

                <div
                  class="col-span-2 flex items-center justify-between rounded-[1.5rem] border border-dashed border-slate-200 p-5"
                >
                  <div>
                    <span
                      class="block text-xs font-bold uppercase tracking-tight text-slate-400"
                      >Coverage</span
                    >
                    <span class="text-sm font-semibold text-slate-700"
                      >{serviceAreas.length || "Custom"} Regions</span
                    >
                  </div>
                  <div class="flex -space-x-4">
                    <div
                      class="h-8 w-8 rounded-full border-2 border-white bg-primary opacity-40"
                    >
                    </div>
                    <div
                      class="h-8 w-8 rounded-full border-2 border-white bg-primary opacity-70"
                    >
                    </div>
                  </div>
                </div>
              </div>

              {
                primaryEmail && (
                  <a
                    href={`mailto:${primaryEmail}`}
                    class="mt-4 block w-full rounded-xl py-3 text-center text-xs font-bold uppercase tracking-widest text-slate-400 hover:text-secondary transition-colors"
                  >
                    Send an email →
                  </a>
                )
              }
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="mx-auto w-[95%] max-w-7xl py-16 md:w-[90%] md:py-24">
      <div class="grid gap-12 lg:grid-cols-12">
        {/* COLUMNA PRINCIPAL */}
        <article class="lg:col-span-8">
          <header class="mb-12">
            <div class="flex items-center gap-3">
              <i class="fas fa-shield-alt text-secondary"></i>
              <span
                class="text-xs font-black uppercase tracking-[0.3em] text-secondary"
              >
                Business Overview
              </span>
            </div>
            <h2
              class="mt-4 text-4xl font-extrabold tracking-tight text-primary md:text-5xl lg:text-6xl"
            >
              Why choose <span class="text-secondary">{data.name}</span>
            </h2>
          </header>

          <div class="grid gap-6 sm:grid-cols-2">
            {/* Card: Primary Services */}
            <div
              class="group relative rounded-[2.5rem] border border-slate-100 bg-slate-50 p-8 transition-all duration-300 hover:bg-white hover:shadow-2xl hover:shadow-slate-200/60"
            >
              <div
                class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-cyan-100 text-cyan-700 transition-colors group-hover:bg-cyan-600 group-hover:text-white"
              >
                <i class="fas fa-tools text-xl"></i>
              </div>
              <h3 class="text-2xl font-black tracking-tight text-primary">
                Primary Services
              </h3>
              <p class="mt-4 text-base leading-relaxed text-slate-600">
                {serviceSummary}
              </p>
              {
                /* Decoración sutil de esquina para coherencia con el primer componente */
              }
              <div
                class="absolute top-6 right-8 opacity-10 transition-opacity group-hover:opacity-100"
              >
                <i class="fas fa-arrow-up-right-from-square text-primary"></i>
              </div>
            </div>

            {/* Card: Why Choose Us */}
            <div
              class="group relative rounded-[2.5rem] border border-slate-100 bg-slate-50 p-8 transition-all duration-300 hover:bg-white hover:shadow-2xl hover:shadow-slate-200/60"
            >
              <div
                class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-indigo-100 text-indigo-700 transition-colors group-hover:bg-indigo-600 group-hover:text-white"
              >
                <i class="fas fa-star text-xl"></i>
              </div>
              <h3 class="text-2xl font-black tracking-tight text-primary">
                Our Value
              </h3>
              <p class="mt-4 text-base leading-relaxed text-slate-600">
                {whyChooseUsText}
              </p>
              <div
                class="absolute top-6 right-8 opacity-10 transition-opacity group-hover:opacity-100"
              >
                <i class="fas fa-arrow-up-right-from-square text-primary"></i>
              </div>
            </div>

            {/* Card: Estimates */}
            <div
              class="group relative rounded-[2.5rem] border border-slate-100 bg-slate-50 p-8 transition-all duration-300 hover:bg-white hover:shadow-2xl hover:shadow-slate-200/60"
            >
              <div
                class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-emerald-100 text-emerald-700 transition-colors group-hover:bg-emerald-600 group-hover:text-white"
              >
                <i class="fas fa-calculator text-xl"></i>
              </div>
              <h3 class="text-2xl font-black tracking-tight text-primary">
                Pricing & Estimates
              </h3>
              <p class="mt-4 text-base leading-relaxed text-slate-600">
                {estimateText}
              </p>
              <div
                class="absolute top-6 right-8 opacity-10 transition-opacity group-hover:opacity-100"
              >
                <i class="fas fa-arrow-up-right-from-square text-primary"></i>
              </div>
            </div>

            {/* Card: Service Area */}
            <div
              class="group relative rounded-[2.5rem] border border-slate-100 bg-slate-50 p-8 transition-all duration-300 hover:bg-white hover:shadow-2xl hover:shadow-slate-200/60"
            >
              <div
                class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-orange-100 text-orange-700 transition-colors group-hover:bg-orange-600 group-hover:text-white"
              >
                <i class="fas fa-map-marked-alt text-xl"></i>
              </div>
              <h3 class="text-2xl font-black tracking-tight text-primary">
                Regional Coverage
              </h3>
              <p class="mt-4 text-base leading-relaxed text-slate-600">
                {serviceAreaText}
              </p>
              <div
                class="absolute top-6 right-8 opacity-10 transition-opacity group-hover:opacity-100"
              >
                <i class="fas fa-arrow-up-right-from-square text-primary"></i>
              </div>
            </div>
          </div>
        </article>

        {/* COLUMNA LATERAL (Sidebar) */}
        <aside class="lg:col-span-4 space-y-8">
          {/* Business Facts */}
          <div
            class="rounded-3xl bg-slate-50 border border-slate-200 p-8 shadow-sm"
          >
            <h3
              class="text-xl font-bold text-primary flex items-center gap-3"
            >
              <i class="fas fa-info-circle text-slate-400"></i>
              Quick Facts
            </h3>
            <dl class="mt-8 space-y-6">
              {
                [
                  { label: "Website", value: siteOrigin, icon: "fa-globe" },
                  {
                    label: "Address",
                    value: data.businessAddress,
                    icon: "fa-map-pin",
                  },
                  {
                    label: "Payments",
                    value: data.methodsPayment,
                    icon: "fa-credit-card",
                  },
                  {
                    label: "License",
                    value: data.businessLicense,
                    icon: "fa-certificate",
                  },
                ].map(
                  (item) =>
                    item.value && (
                      <div class="group">
                        <dt class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400 transition-colors group-hover:text-secondary">
                          <i class={`fas ${item.icon} w-4`} />
                          {item.label}
                        </dt>
                        <dd class="mt-2 text-sm font-semibold text-slate-700 leading-tight">
                          {item.value}
                        </dd>
                      </div>
                    ),
                )
              }
            </dl>
          </div>

          {/* Service Areas (Tags) */}
          <div
            class="rounded-3xl bg-white border-2 border-dashed border-slate-200 p-8"
          >
            <h3
              class="text-lg font-bold text-primary mb-6 flex items-center gap-3"
            >
              <i class="fas fa-city text-slate-400"></i>
              Service Areas
            </h3>
            <div class="flex flex-wrap gap-2">
              {
                serviceAreas.length > 0 ? (
                  serviceAreas.map((area) => (
                    <span class="inline-flex items-center gap-2 rounded-lg bg-slate-100 px-3 py-2 text-[11px] font-bold uppercase tracking-tighter text-slate-600 hover:bg-primary hover:text-white transition-all cursor-default border border-slate-200">
                      <i class="fas fa-check text-[9px]" />
                      {area}
                    </span>
                  ))
                ) : (
                  <p class="text-sm text-slate-500 italic">
                    No areas specified.
                  </p>
                )
              }
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section
      class="relative overflow-hidden border-y border-slate-100 bg-white"
    >
      {/* Decoración de fondo sutil */}
      <div
        class="absolute right-0 top-0 -translate-y-1/2 translate-x-1/2 rounded-full bg-slate-50 p-64 blur-3xl"
      >
      </div>

      <div class="relative mx-auto w-[95%] max-w-7xl py-16 md:w-[90%] md:py-24">
        {/* CABECERA DEL CATÁLOGO */}
        <div
          class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between"
        >
          <div class="max-w-3xl">
            <div class="flex items-center gap-3">
              <i class="fas fa-layer-group text-secondary"></i>
              <span
                class="text-xs font-black uppercase tracking-[0.3em] text-secondary"
              >
                Service Catalog
              </span>
            </div>
            <h2
              class="mt-4 text-4xl font-extrabold tracking-tight text-primary md:text-5xl"
            >
              Explore our <span class="text-slate-400">expertise</span>
            </h2>
            <p class="mt-6 text-xl font-medium leading-relaxed text-slate-700">
              {serviceCatalogIntro}
            </p>
            <p class="mt-3 leading-7 text-slate-500">
              {serviceCatalogDescription}
            </p>
          </div>

          <a
            href="/services"
            class="group inline-flex items-center gap-3 rounded-[1.5rem] border-2 border-slate-100 bg-white px-8 py-4 text-sm font-bold text-primary transition-all hover:border-pribg-primary hover:bg-primary hover:text-white"
          >
            View all services
            <i
              class="fas fa-arrow-right transition-transform group-hover:translate-x-1"
            ></i>
          </a>
        </div>

        {/* LISTA DE SERVICIOS */}
        <div
          class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 auto-rows-[minmax(300px,_auto)]"
        >
          {
            data.services.slice(0,10).map((service, index) => {
              // Definimos clases lógicas para romper la simetría
              const isLarge = index === 0 || index === 4; // La primera y quinta tarjeta son más anchas
              const isTall = index === 1 || index === 5; // La segunda y sexta son más altas
              const isFeatured = index === 9; // La última tarjeta es destacada

              return (
                <article
                  class={`group relative flex flex-col overflow-hidden rounded-[2.5rem] border border-slate-100 p-8 transition-all duration-500 
          ${isLarge ? "sm:col-span-2 bg-primary text-white" : "bg-slate-50 text-primary"} 
          ${isTall ? "lg:row-span-2" : ""} 
            ${isFeatured ? "sm:col-span-2 bg-black text-primary" : ""} 
            hover:bg-white hover:text-primary hover:shadow-2xl hover:shadow-slate-200/50`} 
                >
                  {/* Indicador de Número */}
                  <div class="relative z-10 flex items-start justify-between">
                    <div class="relative flex h-14 w-14 shrink-0 items-center justify-center">
                      <div
                        class={`absolute inset-0 rotate-12 rounded-2xl transition-transform group-hover:rotate-0 
              ${isLarge ? "bg-white/10 group-hover:bg-cyan-600" : "bg-cyan-100 group-hover:bg-primary"}`}
                      />
                      <span
                        class={`relative text-lg font-black ${isLarge ? "text-white" : "text-cyan-700 group-hover:text-white"}`}
                      >
                        {String(index + 1).padStart(2, "0")}
                      </span>
                    </div>

                    <i
                      class={`fas fa-arrow-up-right-from-square opacity-20 group-hover:opacity-100 transition-opacity ${isLarge ? "text-white" : "text-primary"}`}
                    />
                  </div>

                  {/* Contenido */}
                  <div class="relative z-10 mt-auto flex flex-col">
                    <h3
                      class={`font-black leading-tight tracking-tight transition-colors 
            ${isLarge ? "text-3xl md:text-4xl" : "text-2xl"} 
            ${isFeatured ? "text-3xl md:text-4xl" : ""} 
            group-hover:text-secondary`}
                    >
                      {service.title}
                    </h3>

                    <p
                      class={`mt-4 leading-relaxed transition-colors 
            ${isLarge ? "text-slate-300 group-hover:text-slate-600" : "text-slate-600"} 
            ${isTall ? "line-clamp-none" : "line-clamp-3"} ${isFeatured ? "text-slate-700 group-hover:text-slate-600" : "line-clamp-4"}`}
                    >
                      {service.description[0]?.text ||
                        "Explore our professional service options."}
                    </p>

                    <div class="mt-8 flex items-center justify-between">
                      <a
                        href={`/local-profile/${FormatText(service.title)}`}
                        class={`inline-flex items-center gap-2 text-sm font-black uppercase tracking-wider transition-all hover:gap-4
                ${isLarge ? "text-white group-hover:text-primary" : "text-primary"}`}
                      >
                        Learn more
                        <i class="fas fa-arrow-right text-cyan-500" />
                      </a>
                    </div>
                  </div>

                  {/* Icono decorativo de fondo */}
                  <div class="absolute -right-6 -bottom-6 opacity-[0.05] transition-transform duration-700 group-hover:scale-150 group-hover:opacity-[0.1]">
                    <i class="fas fa-briefcase text-[12rem] -rotate-12" />
                  </div>
                </article>
              );
            })
          }
        </div>
      </div>
    </section>

    <section class="mx-auto w-[95%] max-w-7xl py-16 md:w-[90%] md:py-24">
      <div class="grid gap-8 lg:grid-cols-12">
        {/* COLUMNA IZQUIERDA: Horarios (Bento Card Destacada) */}
        <aside class="lg:col-span-4">
          <article
            class="sticky top-8 overflow-hidden rounded-[2.5rem] bg-primary p-8 text-white shadow-2xl shadow-slate-300"
          >
            <div class="relative z-10">
              <div class="flex items-center gap-3">
                <i class="fas fa-clock text-slate-100"></i>
                <span
                  class="text-xs font-black uppercase tracking-[0.3em] text-slate-100"
                >
                  Availability
                </span>
              </div>
              <h2 class="mt-4 text-3xl font-black tracking-tight">
                Business Hours
              </h2>

              <ul class="mt-8 space-y-3">
                {
                  data.dataGeneral.openingHours.length > 0 ? (
                    data.dataGeneral.openingHours.map((item) => (
                      <li class="group flex items-center justify-between rounded-2xl bg-white/5 border border-white/10 px-5 py-4 transition-all hover:bg-white/10">
                        <span class="text-sm font-bold text-slate-100 group-hover:text-white transition-colors">
                          {item.days}
                        </span>
                        <span class="text-sm font-medium text-slate-100">
                          {item.hours}
                        </span>
                      </li>
                    ))
                  ) : (
                    <li class="rounded-2xl bg-white/5 border border-white/10 px-5 py-4 text-slate-400 italic">
                      Contact us for current seasonal hours.
                    </li>
                  )
                }
              </ul>

              <div class="mt-8 rounded-2xl bg-cyan-600 p-6 text-center">
                <p
                  class="text-xs font-black uppercase tracking-widest text-cyan-100"
                >
                  Direct Line
                </p>
                <p class="mt-1 text-xl font-black">
                  {primaryPhone || "Ready to serve"}
                </p>
              </div>
            </div>

            {/* Decoración de fondo */}
            <i
              class="fas fa-calendar-alt absolute -bottom-10 -right-10 text-[12rem] text-white/[0.03] -rotate-12"
            ></i>
          </article>
        </aside>

        {/* COLUMNA DERECHA: FAQs (Grid de Mosaico) */}
        <div class="lg:col-span-8">
          <header class="mb-10">
            <div class="flex items-center gap-3">
              <i class="fas fa-question-circle text-secondary"></i>
              <span
                class="text-xs font-black uppercase tracking-[0.3em] text-secondary"
              >
                Support
              </span>
            </div>
            <h2
              class="mt-4 text-4xl font-extrabold tracking-tight text-primary md:text-5xl"
            >
              Frequently asked <span class="text-slate-400">questions</span>
            </h2>
          </header>

          <div class="grid gap-6 sm:grid-cols-2">
            {/* FAQ 1 */}
            <article
              class="group rounded-[2.5rem] border border-slate-100 bg-slate-50 p-8 transition-all hover:bg-white hover:shadow-xl hover:shadow-slate-200/50"
            >
              <div
                class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-white text-primary shadow-sm transition-colors group-hover:bg-primary group-hover:text-white"
              >
                <i class="fas fa-info text-sm"></i>
              </div>
              <h3 class="text-xl font-black tracking-tight text-primary">
                What kind of business is this?
              </h3>
              <p class="mt-4 text-sm leading-relaxed text-slate-600">
                {data.name} is a local service business specializing in {
                  serviceSummary
                }.
              </p>
            </article>

            {/* FAQ 2 */}
            <article
              class="group rounded-[2.5rem] border border-slate-100 bg-slate-50 p-8 transition-all hover:bg-white hover:shadow-xl hover:shadow-slate-200/50"
            >
              <div
                class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-white text-primary shadow-sm transition-colors group-hover:bg-primary group-hover:text-white"
              >
                <i class="fas fa-map-marker-alt text-sm"></i>
              </div>
              <h3 class="text-xl font-black tracking-tight text-primary">
                What areas do you serve?
              </h3>
              <p class="mt-4 text-sm leading-relaxed text-slate-600">
                {serviceAreaText}
              </p>
            </article>

            {/* FAQ 3 - Destacada en ancho si es posible */}
            <article
